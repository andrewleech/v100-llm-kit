[16.356144, "o", "\u001b[13;1H\u001b[37m\u001b[1m\u25cf\u001b[C\u001b[m\u000fThis is a tiny Flask REST API for managing an in-memory\u001b[Ctodo\u001b[Clist.\u001b[CIt's\u001b[Ca\u001b[Csingle-file\u001b[Capplication\u001b[14;3H(\u001b[37m\u001b[1mapp.py\u001b[m\u000f)\u001b[Cwith\u001b[Ctwo\u001b[Cendpoints:\r\n\u001b[K\r\n  -\u001b[C\u001b[37m\u001b[1mGET /todos\u001b[C\u001b[m\u000f\u2014\u001b[Creturns\u001b[Cthe\u001b[Clist\u001b[Cof\u001b[Ctodos\u001b[Cas\u001b[CJSON\r\n  - \u001b[37m\u001b[1mPOST /todos\u001b[m\u000f \u2014 appends the JSON body as a new todo, returns it with status 201\u001b[K\u001b[18;3H\u001b[K\nStorage is a plain in-memory list, so todos reset\u001b[Con\u001b[Crestart.\u001b[CNo\u001b[Cdatabase,\u001b[Cno\u001b[Cauth.\u001b[21;3HRun\u001b[Cwith\u001b[C\u001b[37m\u001b[1mpython\u001b[Capp.py\u001b[C\u001b[m\u000f\u2014\u001b[Cserves\u001b[Con\u001b[Cport\u001b[C5000.\u001b[23;1H\u001b[31m*\u001b[CFlamb\u00e9ing\u2026\u001b[C\u001b[37m(running\u001b[Cstop\u001b[Chook\u001b[C\u00b7\u001b[C13s\u001b[C\u00b7\u001b[C\u2193\u001b[C90\u001b[Ctokens)\u001b[25;1H\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u001b[26;1H\u276f\u00a0\r\n\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u250