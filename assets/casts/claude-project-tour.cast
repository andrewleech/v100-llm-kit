[20.707851, "o", "\u001b[1d\u001b[K\u001b[2BThe application uses a plain in-mem\u001b[Cry li\u001b[Ct for storage,\u001b[Cmeaning\u001b[Call\u001b[Ctodos\u001b[Care\u001b[Clost\u001b[Cwhen\u001b[Cthe\u001b[4;3Hserver restarts. It can be run using \u001b[37m\u001b[1mpython app.py\u001b[C\u001b[m\u000fo\u001b[C por\u001b[C 5000.\u001b[K\u001b[6;1H\u001b[37m✻\u001b[CChurned for 4s\u001b[39m\u001b[K\u001b[7;3H\u001b[K\r\n\u001b[30m\u001b[40m❯ \u001b[37m\u001b[1mWhat are its two API endpoints?\u001b[m\u000f\u001b[40m                                                                   \u001b[49m\u001b[9;1H\u001b[K\r\n\u001b[37m\u001b[1m●\u001b[C\u001b[m\u000fThe\u001b[Ctwo\u001b[CAPI\u001b[Cendpoints\u001b[Care:\r\n\u001b[K\u001b[12;3H-\u001b[C\u001b[37m\u001b[1mGET /todos\u001b[m\u000f:\u001b[CReturns\u001b[Cthe\u001b[Clist\u001b[Cof\u001b[Ctodos\u001b[Cas\u001b[CJSON.\r\n \u001b[C- \u001b[37m\u001b[1mPOST /todos\u001b[m\u000f: Appends a new\u001b[Ctodo\u001b[Cfrom\u001b[Cthe\u001b[CJSON\u001b[Cbody\u001b[Cand\u001b[Creturns\u001b[Cit\u001b[Cwith\u001b[Ca\u001b[C201\u001b[Cstatus\u001b[Ccode.\u001b[15;1H\u001b[37m✻\u001b[CChurned for 1s\u001b[39m\u001b[K\u001b[16;3H\u001b[K\r\n\u001b[30m\u001b[40m❯ \u001b[37m\u001b[1mShow me the add_todo handler from app.py\u001b[m\u000f\u001b[40m                                                          \u001b[49m\u001b[18;1H\u001b[K\u001b[19;3H\u001b[37mRead \u001b[1m1\u001b[m\u000f\u001b[37m file \u001b[39m\r\n\u001b[K\r\n\u001b[37m\u001b[1m●\u001b[C\u001b[30m@app.route(\u001b[m\u000f\u001b[31m\"/todos\"\u001b[30m\u001b[1m, methods=[\u001b[m\u000f\u001b[31m\"POST\"\u001b[30m\u001b[1m]\u001b[m\u000f)\r\n \u001b[C\u001b[34mdef\u001b[33m \u001b[39madd_todo():\r\n      todos.append(request.json)\u001b[24;7H\u001b[34mreturn\u001b[C\u001b[39mjsonify(request.json),\u001b[C\u001b[32m201\u001b[39m\r\n\u001b[K\r\n\u001b[37m✻\u001b[39m \u001b[37mBaked for 2s\u001b[39m\u001b[K\u001b[29;1H❯ \u001b[32d\u001b[37m← for agents\u001b[29;3H\u001b[m\u000f"]
