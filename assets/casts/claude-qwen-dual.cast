[31.621037, "o", "\u001b[20;1H \u001b[C\u001b[37mRead \u001b[1m1\u001b[m\u000f\u001b[37m file (ctrl+o to expand)\u001b[39m\u001b[K\r\n\u001b[K\r\n\u001b[37m\u001b[1m\u25cf\u001b[C\u001b[m\u000fLines\u001b[C10\u201313:\r\n\u001b[K\r\n  \u001b[30m\u001b[1m@app.route(\u001b[m\u000f\u001b[31m\"/todos\"\u001b[30m\u001b[1m, methods=[\u001b[m\u000f\u001b[31m\"POST\"\u001b[30m\u001b[1m]\u001b[m\u000f)\u001b[K\u001b[25;3H\u001b[34mdef\u001b[33m \u001b[39madd_todo():\u001b[K\u001b[26;7Htodos.append(request.json)\r\n      \u001b[34mreturn\u001b[39m jsonify(request.json), \u001b[32m201\u001b[39m\u001b[K\r\n\u001b[K\r\n  It appends the incoming JSON body directly to the \u001b[37m\u001b[1mtodos\u001b[m\u000f list and returns it with status 201. No\u001b[K\u001b[30;3Hvalidation or fields beyond what's in the request\u001b[Cbody.\u001b[31;3H\u001b[K\r\n\u001b[37m\u273b\u001b[39m\r\u001b[2S\u001b[30;3H\u001b[37mCogitated\u001b[Cfor\u001b[C1s\u001b[39m\r\n\u001b[K\r\n\u001b[K\u001b[37m\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u001b[39m\u001b[32;1H\n\u001b[K\u276f\u00a0\r\n\u001b[K\u001b[37m\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2